---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
export async function getStaticPaths() {
  let works = [];
  try { const d = await import('../../content/works.json'); works = d.default || []; } catch(e) {}
  return works.map(w => ({ params: { slug: w.slug }, props: { work: w } }));
}
const { work } = Astro.props;
---
<Layout lang="en" title={`${work?.title_en || 'Work'} — Moataz Samara`}>
  <Nav lang="en" />
  <main class="wrap" style="padding-top:80px;padding-bottom:80px;max-width:760px;">
    {work ? (
      <div>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-bottom:8px;letter-spacing:0.12em;text-transform:uppercase;">{work.category}</p>
        <h1 style="font-family:var(--font-display);font-size:clamp(36px,5vw,64px);font-weight:300;margin-bottom:16px;">{work.title_en}</h1>
        <p style="font-family:var(--font-mono);font-size:11px;color:var(--muted2);margin-bottom:48px;">{work.year}</p>
        <p style="color:var(--muted);line-height:1.8;font-size:18px;margin-bottom:32px;">{work.description_en}</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {(work.tags || []).map(t => <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted);border:1px solid var(--border);padding:4px 12px;border-radius:var(--radius);">{t}</span>)}
        </div>
      </div>
    ) : <p style="color:var(--muted);">Not found</p>}
  </main>
  <Footer lang="en" />
</Layout>
