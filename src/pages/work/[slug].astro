---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
export async function getStaticPaths() {
  let works = [];
  try { const d = await import('../../content/works.json'); works = d.default || []; } catch(e) {}
  return works.map(w => ({ params: { slug: w.slug }, props: { work: w } }));
}
const { work } = Astro.props;

const gradients = {
  'Digital Transformation': 'linear-gradient(135deg, #0a1f12 0%, #0f3520 50%, #1a5c38 100%)',
  'Brand Identity':         'linear-gradient(135deg, #12091f 0%, #21103d 50%, #3a1d6e 100%)',
  'PR & Strategy':          'linear-gradient(135deg, #1f0e08 0%, #3d1a0a 50%, #6b300f 100%)',
  'Research & Strategy':    'linear-gradient(135deg, #08121f 0%, #0d2035 50%, #153352 100%)',
};
const gradient = work ? (gradients[work.category] || 'linear-gradient(135deg,#111,#1e1e1e)') : '';
---
<Layout lang="en" title={`${work?.title_en || 'Work'} — Moataz Samara`}>
  <Nav lang="en" />
  {work ? (
    <article>
      <!-- HERO BANNER -->
      <div class="project-banner" style={`background:${gradient}`}>
        <div class="wrap banner-inner">
          <a href="/work" class="back-link">← All projects</a>
          <div class="banner-meta">
            <span class="banner-cat">{work.category}</span>
            <span class="banner-year">{work.year}</span>
          </div>
          <h1 class="banner-title">{work.title_en}</h1>
        </div>
      </div>

      <!-- CONTENT -->
      <div class="wrap project-body">
        <div class="project-desc">
          <p>{work.description_en}</p>
        </div>
        <div class="project-tags">
          {(work.tags || []).map(t => <span class="tag">{t}</span>)}
        </div>
        <div class="project-cta">
          <a href="/contact" class="btn-primary">Work with me on something similar</a>
          <a href="/work" class="btn-back">← Back to all projects</a>
        </div>
      </div>
    </article>
  ) : (
    <div class="wrap" style="padding-top:160px;padding-bottom:160px;">
      <p style="color:var(--muted);">Project not found.</p>
    </div>
  )}
  <Footer lang="en" />
</Layout>

<style>
.project-banner {
  padding:160px 0 80px;
  position:relative;
  overflow:hidden;
}
.project-banner::after {
  content:'';position:absolute;inset:0;
  background:linear-gradient(to bottom, transparent 60%, rgba(10,10,10,0.8) 100%);
}
.banner-inner{position:relative;z-index:1;}
.back-link {
  font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;
  text-transform:uppercase;color:rgba(255,255,255,0.4);
  transition:color 0.2s;display:inline-block;margin-bottom:64px;
}
.back-link:hover{color:var(--accent);}
.banner-meta {
  display:flex;align-items:center;gap:16px;margin-bottom:24px;
}
.banner-cat {
  font-family:var(--font-mono);font-size:11px;letter-spacing:0.15em;
  text-transform:uppercase;color:var(--accent);
}
.banner-year {
  font-family:var(--font-mono);font-size:11px;color:rgba(255,255,255,0.3);
}
.banner-title {
  font-family:var(--font-display);
  font-size:clamp(40px,6vw,88px);
  font-weight:300;line-height:0.95;
  letter-spacing:-0.025em;color:var(--text);
  max-width:900px;
}
.project-body {
  padding-top:80px;padding-bottom:120px;max-width:760px;
}
.project-desc {
  margin-bottom:48px;
  padding-bottom:48px;
  border-bottom:1px solid var(--border);
}
.project-desc p {
  font-size:20px;color:var(--text2);line-height:1.8;
}
.project-tags {
  display:flex;flex-wrap:wrap;gap:8px;margin-bottom:64px;
}
.tag {
  font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;
  color:var(--muted);border:1px solid var(--border2);
  padding:6px 16px;border-radius:100px;
}
.project-cta {
  display:flex;align-items:center;gap:24px;flex-wrap:wrap;
}
.btn-primary {
  background:var(--accent);color:#0a0a0a;
  font-family:var(--font-mono);font-size:12px;
  letter-spacing:0.1em;text-transform:uppercase;
  padding:16px 36px;border-radius:var(--radius);
  font-weight:600;transition:opacity 0.2s;
  display:inline-block;
}
.btn-primary:hover{opacity:0.85;}
.btn-back {
  font-family:var(--font-mono);font-size:11px;
  letter-spacing:0.1em;color:var(--muted);transition:color 0.2s;
}
.btn-back:hover{color:var(--text);}
</style>
