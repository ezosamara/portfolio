---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import WorkCard from '../../components/WorkCard.astro';
import Footer from '../../components/Footer.astro';
let works = [];
try { const d = await import('../../content/works.json'); works = d.default || []; } catch(e) {}
---
<Layout lang="en" title="Work — Moataz Samara">
  <Nav lang="en" />
  <main style="padding-top:120px;padding-bottom:120px;">
    <div class="wrap">
      <div class="page-head">
        <p class="page-eyebrow">Selected Work</p>
        <h1 class="page-title">Projects</h1>
        <p class="page-sub">Digital strategy, brand identity, municipal transformation, and political campaigns.</p>
      </div>
      <div class="grid">
        {works.map((w, i) => (
          <div class="reveal" style={`transition-delay:${i * 0.1}s`}>
            <WorkCard
              title={w.title_en}
              category={w.category}
              year={w.year}
              slug={w.slug}
              lang="en"
              description={w.description_en}
            />
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer lang="en" />
</Layout>

<style>
.page-head{margin-bottom:80px;}
.page-eyebrow{font-family:var(--font-mono);font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:16px;}
.page-title{font-family:var(--font-display);font-size:clamp(48px,7vw,96px);font-weight:300;line-height:0.9;letter-spacing:-0.03em;color:var(--text);margin-bottom:24px;}
.page-sub{font-size:16px;color:var(--text2);max-width:500px;line-height:1.6;}
.grid{display:grid;grid-template-columns:1fr;gap:24px;}
@media(min-width:768px){.grid{grid-template-columns:1fr 1fr;}}
</style>

<script>
const obs = new IntersectionObserver((e) => {
  e.forEach(entry => { if(entry.isIntersecting){entry.target.classList.add('visible');obs.unobserve(entry.target);} });
}, {threshold:0.08});
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
