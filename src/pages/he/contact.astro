---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<Layout lang="he" title="צור קשר — מועתז סמארה">
  <Nav lang="he" />
  <main class="wrap" style="padding-top:80px;padding-bottom:80px;max-width:640px;">
    <p style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.15em;color:var(--muted2);text-transform:uppercase;margin-bottom:24px;">צור קשר</p>
    <h1 style="font-family:var(--font-display);font-size:clamp(36px,5vw,64px);font-weight:300;margin-bottom:48px;">בואו נדבר</h1>
    <div style="display:flex;flex-direction:column;gap:24px;">
      <a href="mailto:ezoprmk@gmail.com" class="contact-link">
        <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted2);display:block;margin-bottom:4px;">אימייל</span>
        <span style="font-size:18px;color:var(--accent);">ezoprmk@gmail.com</span>
      </a>
      <a href="tel:0507845633" class="contact-link">
        <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted2);display:block;margin-bottom:4px;">טלפון</span>
        <span style="font-size:18px;color:var(--text);">050-7845633</span>
      </a>
    </div>
  </main>
  <Footer lang="he" />
</Layout>
<style>
.contact-link{display:block;padding:24px;border:1px solid var(--border);border-radius:var(--radius-md);transition:border-color 0.2s;}
.contact-link:hover{border-color:var(--accent);}
</style>
