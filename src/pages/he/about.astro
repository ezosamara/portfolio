---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
let about = {};
try { const d = await import('../../content/about.json'); about = d.default || {}; } catch(e) {}
---
<Layout lang="he" title="אודות — מועתז סמארה">
  <Nav lang="he" />
  <main class="wrap" style="padding-top:80px;padding-bottom:80px;max-width:760px;">
    <p style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.15em;color:var(--muted2);text-transform:uppercase;margin-bottom:24px;">אודות</p>
    <h1 style="font-family:var(--font-display);font-size:clamp(36px,5vw,64px);font-weight:300;margin-bottom:32px;">מועתז סמארה</h1>
    <p style="color:var(--muted);line-height:1.8;font-size:18px;margin-bottom:64px;">{about.bio_he}</p>
    <p style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.15em;color:var(--muted2);text-transform:uppercase;margin-bottom:32px;">ניסיון תעסוקתי</p>
    <div style="display:flex;flex-direction:column;gap:32px;margin-bottom:64px;">
      {(about.experience || []).map((e) => (
        <div style="display:grid;grid-template-columns:120px 1fr;gap:24px;align-items:start;">
          <span style="font-family:var(--font-mono);font-size:11px;color:var(--accent);padding-top:4px;">{e.years}</span>
          <div>
            <p style="font-family:var(--font-display);font-size:20px;font-weight:400;color:var(--text);margin-bottom:4px;">{e.role_he}</p>
            <p style="color:var(--muted);font-size:14px;">{e.org_he}</p>
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer lang="he" />
</Layout>
