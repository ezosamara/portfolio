---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
let works = [];
try { const d = await import('../content/works.json'); works = d.default || []; } catch(e) {}
let about = {};
try { const d = await import('../content/about.json'); about = d.default || {}; } catch(e) {}
---
<Layout lang="en" title="Moataz Samara — Digital Strategy · Brand Design · PR">
  <Nav lang="en" />

  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-wrap">
      <div class="hero-eyebrow reveal">
        <span class="mono-label">Moataz Samara</span>
        <span class="mono-sep">—</span>
        <span class="mono-label">EZO Studio</span>
        <span class="mono-sep">·</span>
        <span class="mono-label accent">Available</span>
      </div>
      <h1 class="hero-title">
        <span class="line reveal reveal-delay-1">Digital strategy,</span>
        <span class="line line-indent reveal reveal-delay-2">brand design,</span>
        <span class="line reveal reveal-delay-3">and the systems</span>
        <span class="line line-indent reveal reveal-delay-4">behind them.</span>
      </h1>
      <div class="hero-footer reveal">
        <div class="hero-desc">
          <p>Project Manager · Digital Marketing · PR Expert</p>
          <p>Arabic · Hebrew · English</p>
        </div>
        <div class="hero-ctas">
          <a href="#work" class="btn-primary">See the work</a>
          <a href="/contact" class="btn-ghost">Get in touch →</a>
        </div>
      </div>
    </div>
    <div class="hero-number">01</div>
  </section>

  <!-- WORK -->
  <section class="section" id="work">
    <div class="wrap">
      <p class="sec-counter reveal">02 · Selected Work</p>
      <div class="work-list">
        {works.map((w, i) => (
          <a href={`/work/${w.slug}`} class="work-row reveal" style={`transition-delay:${i * 0.08}s`}>
            <span class="work-num mono-label">0{i+1}</span>
            <div class="work-info">
              <h2 class="work-title">{w.title_en}</h2>
              <p class="work-meta">{w.description_en?.substring(0, 80)}...</p>
            </div>
            <div class="work-right">
              <span class="work-cat">{w.category}</span>
              <span class="work-year">{w.year}</span>
              <span class="work-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="section section-alt">
    <div class="wrap">
      <p class="sec-counter reveal">03 · What I Do</p>
      <div class="caps-list">
        {[
          {n:'01', t:'Digital Marketing & Campaigns', d:'Campaign management, content strategy, analytics and growth'},
          {n:'02', t:'Brand & Web Development', d:'Identity systems, logo, Webflow builds, automation'},
          {n:'03', t:'Digital Transformation', d:'AI systems, workflow digitization, municipal-scale deployment'},
          {n:'04', t:'PR & Political Strategy', d:'Political campaigns, Knesset candidate management, media'}
        ].map((c, i) => (
          <div class="cap-row reveal" style={`transition-delay:${i * 0.1}s`}>
            <span class="cap-num mono-label">{c.n}</span>
            <h3 class="cap-title">{c.t}</h3>
            <p class="cap-desc">{c.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY MOATAZ -->
  <section class="section">
    <div class="wrap">
      <p class="sec-counter reveal">04 · Unique Profile</p>
      <div class="unique-grid">
        {(about.unique_en || []).map((u, i) => (
          <div class="u-card reveal" style={`transition-delay:${i * 0.08}s`}>
            <span class="u-tag">{u.tag}</span>
            <h3 class="u-title">{u.title}</h3>
            <p class="u-body">{u.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WEBFLOW SITES -->
  <section class="section section-alt">
    <div class="wrap">
      <p class="sec-counter reveal">05 · Webflow Builds</p>
      <div class="sites-list">
        {(about.websites || []).map((s, i) => (
          <a href={s.url} target="_blank" class="site-row reveal" style={`transition-delay:${i * 0.08}s`}>
            <span class="site-cat mono-label">{s.category_en}</span>
            <span class="site-name">{s.name}</span>
            <span class="site-desc">{s.desc_en}</span>
            <span class="site-arrow">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="wrap">
      <h2 class="display-lg reveal">Let's build<br/><em>something real.</em></h2>
      <div class="cta-row reveal reveal-delay-2">
        <a href="/contact" class="btn-primary btn-large">Start a project</a>
        <a href="mailto:ezoprmk@gmail.com" class="cta-email">ezoprmk@gmail.com</a>
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
/* HERO */
.hero {
  min-height:100vh;
  display:flex;
  align-items:flex-end;
  padding-bottom:80px;
  position:relative;
  padding-top:120px;
}
.hero-wrap{width:100%;}
.hero-eyebrow {
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:48px;
  flex-wrap:wrap;
}
.mono-label {
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:var(--text2);
}
.mono-sep{color:var(--border2);font-family:var(--font-mono);}
.accent{color:var(--accent)!important;}
.hero-title {
  display:flex;
  flex-direction:column;
  margin-bottom:80px;
}
.line {
  font-family:var(--font-display);
  font-size:clamp(52px,8.5vw,130px);
  font-weight:300;
  line-height:0.92;
  letter-spacing:-0.03em;
  color:var(--text);
  display:block;
}
.line-indent{padding-left:clamp(40px,8vw,140px);}
.hero-footer {
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  gap:40px;
  flex-wrap:wrap;
  border-top:1px solid var(--border);
  padding-top:32px;
}
.hero-desc p {
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.1em;
  color:var(--text2);
  text-transform:uppercase;
  line-height:2;
}
.hero-ctas{display:flex;gap:16px;align-items:center;}
.hero-number {
  position:absolute;
  bottom:80px;
  right:80px;
  font-family:var(--font-mono);
  font-size:120px;
  font-weight:300;
  color:var(--border);
  line-height:1;
  pointer-events:none;
  user-select:none;
}

/* BUTTONS */
.btn-primary {
  background:var(--accent);
  color:#0a0a0a;
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.12em;
  text-transform:uppercase;
  padding:14px 32px;
  border-radius:var(--radius);
  font-weight:500;
  transition:opacity 0.2s;
  white-space:nowrap;
}
.btn-primary:hover{opacity:0.85;}
.btn-large{padding:18px 48px;font-size:13px;}
.btn-ghost {
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:var(--text2);
  transition:color 0.2s;
}
.btn-ghost:hover{color:var(--text);}

/* SECTIONS */
.section{padding:120px 0;}
.section-alt{background:var(--surface);}
.cta-section{padding:160px 0;text-align:center;}
.cta-section .display-lg{margin-bottom:64px;}
.cta-section em{font-style:normal;color:var(--accent);}
.cta-row{display:flex;align-items:center;justify-content:center;gap:48px;flex-wrap:wrap;}
.cta-email{font-family:var(--font-mono);font-size:13px;color:var(--text2);transition:color 0.2s;}
.cta-email:hover{color:var(--accent);}

/* WORK LIST */
.work-list{display:flex;flex-direction:column;}
.work-row {
  display:grid;
  grid-template-columns:48px 1fr auto;
  gap:32px;
  align-items:center;
  padding:32px 0;
  border-bottom:1px solid var(--border);
  transition:padding-left 0.3s var(--ease);
  cursor:pointer;
}
.work-row:first-child{border-top:1px solid var(--border);}
.work-row:hover{padding-left:16px;}
.work-row:hover .work-arrow{color:var(--accent);transform:translateX(4px);}
.work-num{color:var(--muted);}
.work-title {
  font-family:var(--font-display);
  font-size:clamp(22px,3vw,36px);
  font-weight:300;
  color:var(--text);
  margin-bottom:6px;
  transition:color 0.2s;
}
.work-row:hover .work-title{color:var(--accent);}
.work-meta{font-size:13px;color:var(--muted);line-height:1.5;}
.work-right{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:8px;
}
.work-cat,.work-year{
  font-family:var(--font-mono);
  font-size:10px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted);
}
.work-arrow{font-size:20px;color:var(--text2);transition:color 0.2s,transform 0.2s;}

/* CAPS LIST */
.caps-list{display:flex;flex-direction:column;}
.cap-row {
  display:grid;
  grid-template-columns:48px 1fr 1fr;
  gap:32px;
  padding:40px 0;
  border-bottom:1px solid var(--border);
  align-items:start;
}
.cap-row:first-child{border-top:1px solid var(--border);}
.cap-num{color:var(--muted);padding-top:4px;}
.cap-title {
  font-family:var(--font-display);
  font-size:clamp(20px,2.5vw,28px);
  font-weight:300;
  color:var(--text);
}
.cap-desc{font-size:14px;color:var(--text2);line-height:1.6;max-width:400px;}

/* UNIQUE GRID */
.unique-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:1px;
  background:var(--border);
  border:1px solid var(--border);
}
@media(min-width:768px){.unique-grid{grid-template-columns:1fr 1fr;}}
@media(min-width:1024px){.unique-grid{grid-template-columns:repeat(3,1fr);}}
.u-card {
  background:var(--bg);
  padding:40px;
  transition:background 0.2s;
}
.u-card:hover{background:var(--surface2);}
.u-tag {
  font-family:var(--font-mono);
  font-size:10px;
  letter-spacing:0.15em;
  text-transform:uppercase;
  color:var(--accent);
  display:block;
  margin-bottom:20px;
}
.u-title{
  font-family:var(--font-display);
  font-size:20px;
  font-weight:300;
  color:var(--text);
  margin-bottom:16px;
  line-height:1.3;
}
.u-body{font-size:13px;color:var(--text2);line-height:1.7;}

/* SITES LIST */
.sites-list{display:flex;flex-direction:column;}
.site-row {
  display:grid;
  grid-template-columns:140px 1fr 1fr 24px;
  gap:32px;
  align-items:center;
  padding:28px 0;
  border-bottom:1px solid var(--border);
  transition:padding-left 0.3s var(--ease);
}
.site-row:first-child{border-top:1px solid var(--border);}
.site-row:hover{padding-left:16px;}
.site-row:hover .site-arrow{color:var(--accent);}
.site-cat{color:var(--muted);}
.site-name{
  font-family:var(--font-display);
  font-size:clamp(18px,2vw,24px);
  font-weight:300;
  color:var(--text);
  transition:color 0.2s;
}
.site-row:hover .site-name{color:var(--accent);}
.site-desc{font-size:13px;color:var(--text2);}
.site-arrow{font-size:18px;color:var(--text2);transition:color 0.2s;}
</style>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
