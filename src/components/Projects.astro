---
const projects = [
  {
    title: 'DevBoard',
    desc: 'A real-time developer dashboard aggregating GitHub activity, CI/CD status, and deployment metrics in one clean interface.',
    tags: ['React', 'TypeScript', 'Node.js', 'WebSockets', 'PostgreSQL'],
    github: 'https://github.com/ezosamara',
    demo: '#',
    featured: true,
  },
  {
    title: 'Linksy',
    desc: 'Minimal URL shortener with analytics, custom slugs, and an API — deployed on the edge for sub-10ms redirects worldwide.',
    tags: ['Next.js', 'Vercel Edge', 'Redis', 'Tailwind CSS'],
    github: 'https://github.com/ezosamara',
    demo: '#',
    featured: true,
  },
  {
    title: 'NoteFlow',
    desc: 'Markdown-first note-taking app with live preview, folders, tagging, and local-first sync using IndexedDB.',
    tags: ['Astro', 'TypeScript', 'IndexedDB', 'CSS'],
    github: 'https://github.com/ezosamara',
    demo: '#',
    featured: false,
  },
  {
    title: 'PySearch',
    desc: 'A semantic search CLI tool that indexes your local files and retrieves them via natural-language queries using sentence embeddings.',
    tags: ['Python', 'FastAPI', 'FAISS', 'HuggingFace'],
    github: 'https://github.com/ezosamara',
    demo: null,
    featured: false,
  },
  {
    title: 'Palette AI',
    desc: 'Generate harmonious color palettes from a text prompt or image using AI, then export to CSS variables, Figma tokens, or Tailwind config.',
    tags: ['React', 'OpenAI API', 'Node.js'],
    github: 'https://github.com/ezosamara',
    demo: '#',
    featured: false,
  },
  {
    title: 'Cronster',
    desc: 'Browser-based cron expression builder with a human-readable description, next-run preview, and one-click copy.',
    tags: ['TypeScript', 'Vite', 'CSS'],
    github: 'https://github.com/ezosamara',
    demo: '#',
    featured: false,
  },
];
---

<section id="projects" class="projects">
  <div class="container">
    <p class="section-label">My work</p>
    <h2 class="section-title">Featured Projects</h2>
    <p class="section-subtitle">
      A selection of things I've built — from side projects to production apps.
    </p>

    <div class="projects-grid">
      {projects.map((p) => (
        <article class={`project-card ${p.featured ? 'featured' : ''}`}>
          {p.featured && <span class="featured-badge">Featured</span>}
          <div class="project-body">
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.desc}</p>
            <ul class="project-tags">
              {p.tags.map((t) => <li>{t}</li>)}
            </ul>
          </div>
          <div class="project-links">
            <a href={p.github} target="_blank" rel="noopener" aria-label="GitHub" class="icon-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </a>
            {p.demo && (
              <a href={p.demo} target="_blank" rel="noopener" aria-label="Live demo" class="icon-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="projects-cta">
      <a href="https://github.com/ezosamara" target="_blank" rel="noopener" class="btn-outline">
        View all on GitHub
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .projects .section-subtitle {
    margin-bottom: 48px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 24px 20px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), #a330ff);
    opacity: 0;
    transition: opacity var(--transition);
  }

  .project-card:hover {
    border-color: rgba(124, 106, 255, 0.4);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(124, 106, 255, 0.1);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card.featured {
    border-color: rgba(124, 106, 255, 0.3);
  }

  .project-card.featured::before {
    opacity: 0.5;
  }

  .featured-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent-light);
    background: var(--accent-glow);
    border: 1px solid rgba(124, 106, 255, 0.3);
    border-radius: 100px;
    padding: 3px 10px;
    letter-spacing: 0.05em;
  }

  .project-body {
    flex: 1;
  }

  .project-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }

  .project-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .project-tags li {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--accent-light);
    background: var(--accent-glow);
    border-radius: 4px;
    padding: 3px 8px;
  }

  .project-links {
    display: flex;
    gap: 12px;
    border-top: 1px solid var(--border);
    padding-top: 16px;
    margin-top: auto;
  }

  .icon-link {
    color: var(--text-dim);
    transition: color var(--transition);
  }

  .icon-link:hover {
    color: var(--accent-light);
  }

  .projects-cta {
    margin-top: 48px;
    text-align: center;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: all var(--transition);
  }

  .btn-outline:hover {
    color: var(--accent-light);
    border-color: var(--accent);
    background: var(--accent-glow);
    gap: 12px;
  }
</style>
