---
---

<section id="about" class="about">
  <div class="container about-inner">
    <div class="about-text">
      <p class="section-label">About me</p>
      <h2 class="section-title">Building things that<br />matter on the web</h2>
      <p class="about-para">
        I'm Moataz, a software developer passionate about crafting clean,
        performant applications. I love the full stack — from architecting
        APIs to polishing pixel-perfect interfaces.
      </p>
      <p class="about-para">
        When I'm not coding I'm exploring new technologies, contributing to
        open-source, or thinking about how design and engineering intersect.
        I believe great software is equal parts logic and empathy.
      </p>
      <div class="about-stats">
        <div class="stat">
          <span class="stat-num">3+</span>
          <span class="stat-label">Years of experience</span>
        </div>
        <div class="stat">
          <span class="stat-num">20+</span>
          <span class="stat-label">Projects shipped</span>
        </div>
        <div class="stat">
          <span class="stat-num">10+</span>
          <span class="stat-label">Technologies mastered</span>
        </div>
      </div>
      <a href="#contact" class="btn-link">
        Let's work together
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="about-card">
      <div class="card-inner">
        <div class="avatar-wrap">
          <div class="avatar">MS</div>
          <div class="avatar-ring"></div>
        </div>
        <h3 class="card-name">Moataz Samara</h3>
        <p class="card-role">Software Developer</p>
        <div class="card-divider"></div>
        <ul class="card-details">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            Remote / Worldwide
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            ezoprmk@gmail.com
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
            github.com/ezosamara
          </li>
        </ul>
        <div class="availability">
          <span class="dot"></span>
          Available for opportunities
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 64px;
    align-items: center;
  }

  .about-para {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 20px;
    font-size: 1.02rem;
  }

  .about-stats {
    display: flex;
    gap: 32px;
    margin: 36px 0;
    flex-wrap: wrap;
  }

  .stat-num {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-light);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-light);
    transition: gap var(--transition);
  }

  .btn-link:hover { gap: 12px; }

  /* Card */
  .about-card {
    position: relative;
  }

  .card-inner {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 28px;
    text-align: center;
  }

  .avatar-wrap {
    position: relative;
    width: 80px;
    height: 80px;
    margin: 0 auto 16px;
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #a330ff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    position: relative;
    z-index: 1;
  }

  .avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #a330ff);
    opacity: 0.3;
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.08); opacity: 0.1; }
  }

  .card-name {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .card-role {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .card-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 20px;
  }

  .card-details {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .card-details li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .card-details li svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .availability {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 100px;
    padding: 6px 14px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    animation: dot-pulse 2s ease infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4); }
    50% { box-shadow: 0 0 0 5px rgba(74, 222, 128, 0); }
  }

  @media (max-width: 860px) {
    .about-inner {
      grid-template-columns: 1fr;
    }
    .about-card { max-width: 340px; }
  }
</style>
