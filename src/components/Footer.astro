---
const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';
---
<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-left">
      <p class="footer-name">Moataz Samara · EZO Studio</p>
      <p class="footer-copy">© 2025</p>
    </div>
    <div class="footer-right">
      <a href="mailto:ezoprmk@gmail.com" class="footer-link">Email</a>
      <a href="https://www.linkedin.com/in/moataz-samara-ab21651b6/" target="_blank" class="footer-link">LinkedIn</a>
      <a href={isHe ? '/' : '/he'} class="footer-link footer-lang">{isHe ? 'EN' : 'עברית'}</a>
    </div>
  </div>
</footer>
<style>
.footer{border-top:1px solid var(--border);padding:40px 0;}
.footer-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;}
.footer-name{font-family:var(--font-mono);font-size:11px;color:var(--text2);letter-spacing:0.08em;}
.footer-copy{font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-top:4px;}
.footer-right{display:flex;gap:32px;}
.footer-link{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:0.08em;transition:color 0.2s;}
.footer-link:hover{color:var(--text);}
.footer-lang{color:var(--accent);}
</style>
