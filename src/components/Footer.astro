---
const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';
---
<footer class="footer">
  <div class="wrap footer-inner">
    <span class="f-name">Moataz Samara · EZO Studio</span>
    <div class="f-links">
      <a href="mailto:ezoprmk@gmail.com">Email</a>
      <a href="https://www.linkedin.com/in/moataz-samara-ab21651b6/" target="_blank">LinkedIn</a>
      <a href={isHe ? '/' : '/he'}>{isHe ? 'EN' : 'עברית'}</a>
    </div>
  </div>
</footer>
<style>
.footer{border-top:1px solid var(--border);padding:32px 0;margin-top:96px;}
.footer-inner{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.f-name{font-family:var(--font-mono);font-size:11px;color:var(--muted2);letter-spacing:0.08em;}
.f-links{display:flex;gap:24px;}
.f-links a{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:0.08em;transition:color 0.2s;}
.f-links a:hover{color:var(--text);}
</style>
