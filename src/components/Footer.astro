---
const { lang = 'en' } = Astro.props;
const isHe = lang === 'he';
---
<footer class="footer">
  <div class="wrap footer-inner">
    <span class="footer-logo"><span class="bracket">[</span>EZO<span class="bracket">]</span> · Moataz Samara</span>
    <div class="footer-links">
      <a href="mailto:ezoprmk@gmail.com" class="footer-link">Email</a>
      <a href="https://www.linkedin.com/in/moataz-samara-ab21651b6/" target="_blank" class="footer-link">LinkedIn</a>
      <a href={isHe ? '/' : '/he'} class="footer-link lang">{isHe ? 'EN' : 'עברית'}</a>
    </div>
    <span class="footer-copy">© 2025</span>
  </div>
</footer>
<style>
.footer{border-top:1px solid var(--border);padding:32px 0;margin-top:0;}
.footer-inner{display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;}
.footer-logo{font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;color:var(--text2);}
.bracket{color:var(--accent);}
.footer-links{display:flex;gap:28px;}
.footer-link{font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;color:var(--muted);transition:color 0.2s;text-transform:uppercase;}
.footer-link:hover{color:var(--accent);}
.lang{color:var(--accent)!important;}
.footer-copy{font-family:var(--font-mono);font-size:11px;color:var(--muted);}
</style>
