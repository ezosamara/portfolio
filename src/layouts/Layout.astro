---
import '../styles/global.css';
const { lang = 'en', title = 'Moataz Samara' } = Astro.props;
const isHe = lang === 'he';
---
<!DOCTYPE html>
<html lang={lang} dir={isHe ? 'rtl' : 'ltr'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {isHe
    ? <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&family=Syne:wght@300;400;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    : <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Syne:wght@300;400;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  }
</head>
<body><slot /></body>
</html>
